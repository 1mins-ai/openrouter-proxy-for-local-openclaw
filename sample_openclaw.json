"models": {
    "mode": "merge",
    "providers": {
       "myproxy": {
       "baseUrl": "http://host.docker.internal:3060/v1",
        "apiKey": "sk-or-v1-ssxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
        "api": "openai-completions",
        "authHeader": true,
        "models": [
          {
            "id": "google/gemini-3-flash-preview",
            "name": "google/gemini-3-flash-preview"
          }
        ]
      }
     }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "myproxy/google/gemini-3-flash-preview"
      },
      "models": {
        "myproxy/google/gemini-3-flash-preview": { 
        "alias": "Gemini 3 flash (Proxy)"
      }
      },
      "workspace": "/home/node/.openclaw/workspace",
      "compaction": {
        "mode": "safeguard"
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      }
    }
  },
